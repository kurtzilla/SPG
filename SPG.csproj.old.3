<Project Sdk="Godot.NET.Sdk/4.6.2">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>SPG</RootNamespace>
    <AssemblyName>SPG</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="src\SPG.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="src\Core\**\*.cs" />
    <Compile Remove="src\obj\**\*.cs" />
    <Compile Remove="src\bin\**\*.cs" />
    <Compile Remove="artifacts\**\*.cs" />
    <Compile Remove="tests\**\*.cs" />
  </ItemGroup>
</Project>
